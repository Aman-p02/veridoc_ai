# ==============================================================================
# Environment Configuration for Self-Correcting Financial Document Analyst
# ==============================================================================

# LLM Providers Configuration (At least one is required)
# ------------------------------------------------------------------------------
# Set this to use OpenAI models (e.g. gpt-4o, gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Set this to use Google Gemini models (e.g. gemini-1.5-pro, gemini-1.5-flash)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: LangSmith Tracing for debugging
# ------------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langchain_api_key_here
# LANGCHAIN_PROJECT=financial-agent-analyst
